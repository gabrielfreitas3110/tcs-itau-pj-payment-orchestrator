            "url": {
              "raw": "{{fraudBaseUrl}}/actuator/health",
              "host": ["{{fraudBaseUrl}}"],
              "path": ["actuator", "health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Fraud UP', () => pm.response.to.have.status(200));",
                  "pm.test('status UP', () => pm.expect(pm.response.json().status).to.eql('UP'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Settlement Health (8082)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{settlementBaseUrl}}/actuator/health",
              "host": ["{{settlementBaseUrl}}"],
              "path": ["actuator", "health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Settlement UP', () => pm.response.to.have.status(200));",
                  "pm.test('status UP', () => pm.expect(pm.response.json().status).to.eql('UP'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Notification Health (8083)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{notificationBaseUrl}}/actuator/health",
              "host": ["{{notificationBaseUrl}}"],
              "path": ["actuator", "health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Notification UP', () => pm.response.to.have.status(200));",
                  "pm.test('status UP', () => pm.expect(pm.response.json().status).to.eql('UP'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 - Payment API (Bearer token auto)",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{accessToken}}",
            "type": "string"
          }
        ]
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const now = Date.now();",
              "const expiry = parseInt(pm.collectionVariables.get('tokenExpiry') || '0');",
              "if (expiry > now) return;",
              "",
              "const clientId     = pm.collectionVariables.get('cognitoClientId');",
              "const clientSecret = pm.collectionVariables.get('cognitoClientSecret');",
              "const username     = pm.collectionVariables.get('cognitoUsername');",
              "const password     = pm.collectionVariables.get('cognitoPassword');",
              "const region       = pm.collectionVariables.get('cognitoRegion');",
              "",
              "if (!clientId || !clientSecret || !username || !password) {",
              "    console.warn('Cognito vars nao configuradas — defina cognitoClientId, cognitoClientSecret, cognitoUsername e cognitoPassword.');",
              "    return;",
              "}",
              "",
              "const message    = username + clientId;",
              "const secretHash = CryptoJS.enc.Base64.stringify(CryptoJS.HmacSHA256(message, clientSecret));",
              "",
              "pm.sendRequest({",
              "    url: `https://cognito-idp.${region}.amazonaws.com/`,",
              "    method: 'POST',",
              "    header: {",
              "        'Content-Type': 'application/x-amz-json-1.1',",
              "        'X-Amz-Target': 'AWSCognitoIdentityProviderService.InitiateAuth'",
              "    },",
              "    body: {",
              "        mode: 'raw',",
              "        raw: JSON.stringify({",
              "            AuthFlow: 'USER_PASSWORD_AUTH',",
              "            ClientId: clientId,",
              "            AuthParameters: {",
              "                USERNAME: username,",
              "                PASSWORD: password,",
              "                SECRET_HASH: secretHash",
              "            }",
              "        })",
              "    }",
              "}, function(err, res) {",
              "    if (err) { console.error('Cognito error:', err); return; }",
              "    const body = res.json();",
              "    if (body.AuthenticationResult) {",
              "        const token = body.AuthenticationResult.AccessToken;",
              "        const expiresIn = body.AuthenticationResult.ExpiresIn;",
              "        pm.collectionVariables.set('accessToken', token);",
              "        pm.collectionVariables.set('tokenExpiry', String(Date.now() + (expiresIn - 60) * 1000));",
              "        console.log('Token renovado. Expira em', expiresIn, 'segundos.');",
              "    } else {",
              "        console.error('Falha no login Cognito:', JSON.stringify(body));",
              "    }",
              "});"
            ]
          }
        }
      ],
      "item": [
        {
          "name": "Create Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cnpj\": \"{{cnpj}}\",\n  \"amount\": {{amount}},\n  \"currency\": \"{{currency}}\",\n  \"merchantId\": \"{{merchantId}}\"\n}"
            },
            "url": {
              "raw": "{{paymentBaseUrl}}/api/v1/payments",
              "host": ["{{paymentBaseUrl}}"],
              "path": ["api", "v1", "payments"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('paymentId', body.id);",
                  "console.log('paymentId salvo:', body.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Payment By ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{paymentBaseUrl}}/api/v1/payments/{{paymentId}}",
              "host": ["{{paymentBaseUrl}}"],
              "path": ["api", "v1", "payments", "{{paymentId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('ID confere', () => {",
                  "  const id = pm.collectionVariables.get('paymentId');",
                  "  pm.expect(pm.response.json().id).to.eql(id);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Fraud",
      "item": [
        {
          "name": "Process payment.created",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{$guid}}\",\n  \"eventType\": \"payment.created.v1\",\n  \"occurredAt\": \"{{$isoTimestamp}}\",\n  \"paymentId\": \"{{paymentId}}\",\n  \"cnpj\": \"{{cnpj}}\",\n  \"amount\": {{amount}},\n  \"currency\": \"{{currency}}\",\n  \"merchantId\": \"{{merchantId}}\"\n}"
            },
            "url": {
              "raw": "{{fraudBaseUrl}}/events/payment-created",
              "host": ["{{fraudBaseUrl}}"],
              "path": ["events", "payment-created"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('fraudEventId', body.eventId);",
                  "pm.collectionVariables.set('fraudDecision', body.decision);",
                  "pm.test('decision presente', () => pm.expect(['APPROVED','REJECTED']).to.include(body.decision));",
                  "console.log('Fraud decision:', body.decision, '| ruleScore:', body.ruleScore, '| anomalyScore:', body.anomalyScore);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03 - Settlement",
      "item": [
        {
          "name": "Handle Fraud Decision",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentId\": \"{{paymentId}}\",\n  \"decision\": \"{{fraudDecision}}\",\n  \"eventId\": \"{{fraudEventId}}\"\n}"
            },
            "url": {
              "raw": "{{settlementBaseUrl}}/api/v1/settlement/fraud-decision",
              "host": ["{{settlementBaseUrl}}"],
              "path": ["api", "v1", "settlement", "fraud-decision"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('settlementStatus', body.status);",
                  "console.log('Settlement status:', body.status);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Settlement Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{settlementBaseUrl}}/api/v1/settlement/{{paymentId}}",
              "host": ["{{settlementBaseUrl}}"],
              "path": ["api", "v1", "settlement", "{{paymentId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "04 - Notification",
      "item": [
        {
          "name": "Send Notification",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentId\": \"{{paymentId}}\",\n  \"status\": \"{{settlementStatus}}\"\n}"
            },
            "url": {
              "raw": "{{notificationBaseUrl}}/api/v1/notifications",
              "host": ["{{notificationBaseUrl}}"],
              "path": ["api", "v1", "notifications"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 ou 201', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
