{
  "info": {
    "_postman_id": "f2f0b3bf-32d5-4ccf-84f6-3fb43c95a1fd",
    "name": "PJ Payment Orchestrator - Auth + Endpoints",
    "description": "Collection completa com Cognito auto-login e fluxo end-to-end: Payment → Fraud → Settlement → Notification.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
